{
  "name": "Assembly - embedded devcontainer",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.makefile-tools",
        "marus25.cortex-debug",
        "ms-vscode.hexeditor",
        "webfreak.debug"
      ]
    }
  },
  "postCreateCommand": "nasm -v && arm-none-eabi-gcc --version",
  "remoteUser": "vscode"
}
